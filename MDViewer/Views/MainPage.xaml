<Page
    x:Class="MDViewer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MDViewer.Views"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:models="using:MDViewer.Models"
    RequestedTheme="Dark"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <CommandBar Grid.Row="0" Grid.ColumnSpan="3" DefaultLabelPosition="Right" Background="Transparent">
            <AppBarButton Icon="OpenFile" Label="Open" Command="{x:Bind ViewModel.OpenCommand}" />
            <AppBarButton Icon="Save" Label="Save" Command="{x:Bind ViewModel.SaveCommand}" />
            <AppBarButton Icon="Cancel" Label="Close" Command="{x:Bind ViewModel.CloseDocumentCommand}" />
            <AppBarButton Icon="Share" Label="Export" Command="{x:Bind ViewModel.ExportCommand}" />
            <AppBarButton Icon="Globe" Label="Crawl" Command="{x:Bind ViewModel.CrawlCommand}" />
            <AppBarButton Label="Fetch Pandoc" Command="{x:Bind ViewModel.FetchPandocCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE896;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton Icon="Edit" Label="Format" Command="{x:Bind ViewModel.FormatCommand}" />
            <AppBarButton Icon="Sort" Label="Reflow" Command="{x:Bind ViewModel.ReflowCommand}" />
            <AppBarSeparator />
            <AppBarToggleButton
                Label="Raw"
                IsChecked="{x:Bind ViewModel.IsRawView, Mode=TwoWay}"
                IsEnabled="{x:Bind ViewModel.CanRenderRichMarkdown, Mode=OneWay}">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE943;" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <AppBarButton Icon="ClosePane" Label="Exit" Command="{x:Bind ViewModel.ExitCommand}" />
        </CommandBar>

        <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <TreeView 
                x:Name="HeadingTreeView"
                Margin="0,12,0,0"
                ItemInvoked="HeadingTreeView_ItemInvoked"
                SelectionChanged="HeadingTreeView_SelectionChanged"
                ItemsSource="{x:Bind ViewModel.HeadingNodes, Mode=OneWay}">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="models:HeadingNode">
                        <TreeViewItem
                            Content="{x:Bind Title}"
                            Tag="{x:Bind}"
                            ItemsSource="{x:Bind Children}" />
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <controls:GridSplitter 
            Grid.Row="1" 
            Grid.Column="1" 
            Width="6" 
            HorizontalAlignment="Center" 
            Background="Transparent" />

        <Grid Grid.Row="1" Grid.Column="2">
            <ScrollViewer
                x:Name="RichMarkdownScrollViewer"
                Padding="48,32,48,64"
                Loaded="RichMarkdownScrollViewer_Loaded"
                SizeChanged="RichMarkdownScrollViewer_SizeChanged"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.RichViewVisibility, Mode=OneWay}">
                <controls:MarkdownTextBlock
                    x:Name="RichMarkdownTextBlock"
                    Text="{x:Bind ViewModel.RenderedMarkdown, Mode=OneWay}"
                    Background="Transparent"
                    Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"
                    FontSize="{x:Bind ViewModel.ContentFontSize, Mode=OneWay}"
                    Header1FontSize="{x:Bind ViewModel.Header1FontSize, Mode=OneWay}"
                    Header1FontWeight="Bold"
                    Header2FontSize="{x:Bind ViewModel.Header2FontSize, Mode=OneWay}"
                    Header3FontSize="{x:Bind ViewModel.Header3FontSize, Mode=OneWay}"
                    Header4FontSize="{x:Bind ViewModel.Header4FontSize, Mode=OneWay}"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Left" />
            </ScrollViewer>

            <TextBox
                x:Name="RawMarkdownTextBox"
                Padding="48,32,48,64"
                Text="{x:Bind ViewModel.CurrentDocument.RawMarkdown, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.RawViewVisibility, Mode=OneWay}"
                IsReadOnly="True"
                FontFamily="Consolas"
                FontSize="{x:Bind ViewModel.ContentFontSize, Mode=OneWay}"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>

        <Border
            Grid.Row="2"
            Grid.ColumnSpan="3"
            MinHeight="32"
            Padding="12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{x:Bind ViewModel.DocumentStatisticsText, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
                    <Button
                        Width="32"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.ZoomOutCommand}">
                        <ToolTipService.ToolTip>Zoom out</ToolTipService.ToolTip>
                        <FontIcon Glyph="&#xE71F;" FontSize="14" />
                    </Button>
                    <Button
                        MinWidth="48"
                        Height="28"
                        Padding="8,0"
                        Command="{x:Bind ViewModel.ResetZoomCommand}">
                        <ToolTipService.ToolTip>Reset zoom</ToolTipService.ToolTip>
                        <TextBlock Text="{x:Bind ViewModel.ZoomText, Mode=OneWay}" />
                    </Button>
                    <Button
                        Width="32"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.ZoomInCommand}">
                        <ToolTipService.ToolTip>Zoom in</ToolTipService.ToolTip>
                        <FontIcon Glyph="&#xE8A3;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Background="#99000000"
            Visibility="{x:Bind ViewModel.CrawlOverlayVisibility, Mode=OneWay}">
            <StackPanel
                Width="360"
                Padding="24"
                Spacing="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ProgressRing
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsCrawling, Mode=OneWay}" />
                <TextBlock
                    Text="{x:Bind ViewModel.CrawlStatus, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />
                <Button
                    Content="Cancel"
                    Command="{x:Bind ViewModel.CancelCrawlCommand}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
